# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://atlas:atlas@localhost:5432/atlas_dev"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── API server ───────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN="http://localhost:3000"

# ─── Web frontend ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
# Model to use (default: gpt-4o)
# OPENAI_MODEL="gpt-4o"

# ─── ElevenLabs TTS ───────────────────────────────────────────────────────────
ELEVENLABS_API_KEY="..."
# Default voice ID (Rachel)
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"

# ─── Google Gemini (image generation + Veo video) ─────────────────────────────
GEMINI_API_KEY="..."

# ─── Video generation provider ──────────────────────────────────────────────
# Direct providers: "kling" (uses FAL_KEY), "veo" (uses GEMINI_API_KEY), "seedance" (uses FAL_KEY)
# Replicate providers: "replicate-veo", "replicate-kling", "replicate-seedance", "replicate-seedance-lite"
# VIDEO_PROVIDER="kling"

# ─── fal.ai (required for kling/seedance providers) ─────────────────────────
FAL_KEY="..."
# KLING_MODEL_ID="fal-ai/kling-video/v2.6/pro/image-to-video"
# KLING_DURATION="5"

# ─── Replicate (required for replicate-* providers) ─────────────────────────
REPLICATE_API_TOKEN="r8_..."

# ─── Brave Search ─────────────────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY="BSA..."

# ─── YouTube Data API v3 ──────────────────────────────────────────────────────
YOUTUBE_API_KEY="AIza..."

# ─── S3-compatible storage ────────────────────────────────────────────────────
S3_BUCKET="atlas-media"
# Leave S3_ENDPOINT blank to use AWS default endpoint
# S3_ENDPOINT="http://localhost:9000"
AWS_ACCESS_KEY_ID="..."
AWS_SECRET_ACCESS_KEY="..."
AWS_REGION="us-east-1"

# ─── Mock providers (set to true to skip real API calls during local dev) ─────
USE_MOCK_LLM=true
USE_MOCK_TTS=true
USE_MOCK_IMAGE=true
USE_MOCK_SEARCH=true
USE_MOCK_YOUTUBE=true
USE_MOCK_STORAGE=true
