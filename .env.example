# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://atlas:atlas@localhost:5432/atlas_dev"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── API server ───────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN="http://localhost:3000"

# ─── Web frontend ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
# Model to use (default: gpt-4o)
# OPENAI_MODEL="gpt-4o"

# ─── ElevenLabs TTS ───────────────────────────────────────────────────────────
ELEVENLABS_API_KEY="..."
# Default voice ID (Rachel)
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"

# ─── Google Gemini (image generation) ────────────────────────────────────────
GEMINI_API_KEY="..."

# ─── Brave Search ─────────────────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY="BSA..."

# ─── YouTube Data API v3 ──────────────────────────────────────────────────────
YOUTUBE_API_KEY="AIza..."

# ─── S3-compatible storage ────────────────────────────────────────────────────
S3_BUCKET="atlas-media"
# Leave S3_ENDPOINT blank to use AWS default endpoint
# S3_ENDPOINT="http://localhost:9000"
AWS_ACCESS_KEY_ID="..."
AWS_SECRET_ACCESS_KEY="..."
AWS_REGION="us-east-1"

# ─── Mock providers (set to true to skip real API calls during local dev) ─────
USE_MOCK_LLM=true
USE_MOCK_TTS=true
USE_MOCK_IMAGE=true
USE_MOCK_SEARCH=true
USE_MOCK_YOUTUBE=true
USE_MOCK_STORAGE=true
